{
  "name": "harbourmaster",
  "version": "1.0.0",
  "description": "Deploy readiness intelligence agent — 6 sources, one verdict, under 10 seconds.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "harbourmaster": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "check": "tsx src/index.ts check",
    "watch": "tsx src/index.ts watch",
    "seed:sentry": "tsx scripts/seed-sentry.ts",
    "seed:pagerduty": "tsx scripts/seed-pagerduty.ts",
    "seed:linear": "tsx scripts/seed-linear.ts",
    "seed:all": "npm run seed:sentry && npm run seed:pagerduty && npm run seed:linear"
  },
  "keywords": [
    "deploy",
    "readiness",
    "coral",
    "gemini",
    "devops",
    "cli"
