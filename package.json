  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "@slack/web-api": "^7.8.0",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "dotenv": "^16.5.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@sentry/node": "^9.47.1",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
