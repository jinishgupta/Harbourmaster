# ─── API Keys ────────────────────────────────────────────────
# Gemini (required) — get from https://aistudio.google.com
GEMINI_API_KEY=

# ─── Coral Sources ───────────────────────────────────────────
# GitHub — https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_OWNER=withcoral
GITHUB_REPO=coral

# Sentry — https://sentry.io → Settings → Developer Settings → Internal Integration
SENTRY_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=payments-service
# Sentry DSN (for seed script) — Settings → Client Keys (DSN)
SENTRY_DSN=

# Datadog — https://app.datadoghq.com → Organization Settings → API/App Keys
DD_API_KEY=
DD_APPLICATION_KEY=
DD_SITE=datadoghq.com

# PagerDuty — https://developer.pagerduty.com → API Access Keys
PAGERDUTY_API_TOKEN=

# StatusGator — https://statusgator.com → Dashboard → API
STATUSGATOR_API_TOKEN=
STATUSGATOR_BOARD_ID=

# Linear — https://linear.app → Settings → API → Personal API Keys
LINEAR_API_KEY=

# ─── Notifications ───────────────────────────────────────────
# Slack — https://api.slack.com/apps → OAuth & Permissions → Bot Token
SLACK_TOKEN=
SLACK_CHANNEL_ID=
